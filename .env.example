# Set these as Environment Variables in your Vercel project
# (Project → Settings → Environment Variables). For local `vercel dev`, copy to .env.

SPLITWISE_TOKEN=your_splitwise_api_key      # required
SPLITWISE_GROUP_ID=12345678                 # required — your burrito group's ID
CURRENCY=UYU
DEFAULT_PRICE=440
# APP_PIN=1234                              # optional: require a PIN to charge
